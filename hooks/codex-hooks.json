{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"<jinhua-dir>/hooks/codex_user_prompt_submit.py\"",
            "timeout": 5,
            "statusMessage": "Checking jinhua correction gate"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"<jinhua-dir>/hooks/codex_post_tool_use.py\"",
            "timeout": 5,
            "statusMessage": "Updating jinhua invocation guard"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"<jinhua-dir>/hooks/codex_stop.py\"",
            "timeout": 5,
            "statusMessage": "Checking jinhua output state"
          }
        ]
      }
    ]
  }
}
